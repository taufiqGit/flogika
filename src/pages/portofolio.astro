---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="view-transition" content="same-origin">
<title>Portfolio | Web Agency Inc</title>
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js">
</script>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap">
<style>:root { --uber-black: #000000; --uber-white: #FFFFFF; --uber-blue: #276EF1; --uber-gray: #F3F3F3; } body { font-family: 'Inter', sans-serif; background-color: var(--uber-white); color: var(--uber-black); } .tracking-tight-uber { letter-spacing: -0.04em; } @view-transition { navigation: auto; } ::view-transition-old(main-content) { animation: 0.25s ease-out both fade-out; } ::view-transition-new(main-content) { animation: 0.25s ease-in 0.1s both fade-in; } @keyframes fade-out { from { opacity: 1; } to { opacity: 0; } } @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } } .project-card:hover .project-image { transform: scale(1.05); } .filter-btn.active { background-color: black; color: white; }</style>  <style>sd-component { display: block; }</style>
  <script is:inline src="https://cdn.jsdelivr.net/npm/petite-vue@0.4.1/dist/petite-vue.iife.js" defer>
</script>
</head>
<body>
<div class="min-h-screen bg-white flex flex-col">
<!-- component: Navigation (0cd407ea-25b8-47d5-a494-75ed28710ec3) -->
<div v-scope='{ ...{"activeItem":"portfolio","homeHref":"/","servicesHref":"https://draft-6895e637-8acf-4f1b-b88e-5bad8392c4c2.preview.superdesign.dev","portfolioHref":"https://draft-0864fc93-5f29-49b6-8f49-133cd8109984.preview.superdesign.dev","aboutHref":"#about","contactHref":"https://draft-e11fecc2-0b32-4174-ab08-ccd3c29b1ab1.preview.superdesign.dev"}, $emit() {} }'>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100 px-6 py-4 flex items-center justify-between">
<div class="flex items-center gap-8">
<a :href="homeHref" id="nav-logo-link" class="flex items-center">
<img src="https://vgbujcuwptvheqijyjbe.supabase.co/storage/v1/object/public/hmac-uploads/uploads/f9d8c84d-888c-4030-bf75-477f0928ee4d/1766720562184-a0cfc534/uber_logo.svg" alt="Logo" class="h-6 w-auto">
</a>
<div class="hidden md:flex items-center gap-6">
<a :href="servicesHref" id="nav-services-link" class="text-sm font-medium transition-opacity" :class="{ 'text-black opacity-100': activeItem === 'services', 'text-black/60 hover:opacity-70': activeItem !== 'services' }">Services</a>
<a :href="portfolioHref" id="nav-portfolio-link" class="text-sm font-medium transition-opacity" :class="{ 'text-black opacity-100': activeItem === 'portfolio', 'text-black/60 hover:opacity-70': activeItem !== 'portfolio' }">Portfolio</a>
<a :href="aboutHref" id="nav-about-link" class="text-sm font-medium transition-opacity" :class="{ 'text-black opacity-100': activeItem === 'about', 'text-black/60 hover:opacity-70': activeItem !== 'about' }">About</a>
</div>
</div>
<div class="flex items-center gap-4">
<a :href="contactHref" id="nav-cta-btn" class="bg-black text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-zinc-800 transition-all">Contact Us</a>
<button @click="$emit('toggleMobileMenu')" class="md:hidden flex items-center p-2">
<iconify-icon icon="lucide:menu" class="text-2xl">
</iconify-icon>
</button>
</div>
</nav>
</div>
<!-- /component: Navigation (0cd407ea-25b8-47d5-a494-75ed28710ec3) -->
<main class="flex-1 pt-24" style="view-transition-name: main-content">
<section class="px-6 lg:px-12 py-16 lg:py-24 max-w-7xl mx-auto">
<div class="max-w-3xl space-y-6">
<div class="inline-block bg-black text-white px-3 py-1 text-[10px] uppercase tracking-widest font-bold">Portfolio</div>
<h1 class="text-6xl lg:text-7xl font-extrabold tracking-tight-uber leading-none">Engineered for <span class="text-[#276EF1]">impact</span>.</h1>
<p class="text-xl text-zinc-600">A collection of high-performance digital products, platforms, and interfaces built for global industry leaders.</p>
</div>
</section>
<section class="px-6 lg:px-12 border-b border-zinc-100 pb-8 max-w-7xl mx-auto mb-12">
