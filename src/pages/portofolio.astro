<button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">Web Dev</button>
<button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">Cloud Systems</button>
<button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">E-commerce</button>
<button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">AI/ML</button>
</div>
</section>
<section class="px-6 lg:px-12 pb-24 max-w-7xl mx-auto">
<div class="grid md:grid-cols-2 lg:grid-cols-2 gap-x-12 gap-y-20">
<div class="group cursor-pointer">
<div class="overflow-hidden bg-zinc-100 aspect-[16/10] mb-8 relative rounded-lg">
<img src="https://pquxfbbxflqvtidtlrhl.supabase.co/storage/v1/object/public/hmac-uploads/brand/aa611a48-0f31-4fc3-91b8-a97e15fbee97/assets/7d9bed9b-8b0f-4125-90a3-af750783d201.png" alt="Logistics Platform" class="project-image w-full h-full object-cover transition-transform duration-700">
</div>
<div class="flex items-start justify-between gap-4 mb-4">
<div class="space-y-1">
