<h3 class="text-3xl font-extrabold tracking-tight-uber">SwiftTrack Enterprise</h3>
</div>
<a href="#" id="project-1-link" class="w-12 h-12 rounded-full border border-zinc-200 flex items-center justify-center group-hover:bg-black group-hover:text-white transition-all">
<iconify-icon icon="lucide:arrow-up-right" class="text-xl">
</iconify-icon>
</a>
</div>
