---
import "../styles/global.css";
import AgencyPageHead from "../components/AgencyPageHead.astro";
import AgencyNavigation from "../components/AgencyNavigation.astro";
import AgencyFooter from "../components/AgencyFooter.astro";
import PortfolioHeroSection from "../components/PortfolioHeroSection.astro";
import PortfolioFilterSection from "../components/PortfolioFilterSection.astro";
import PortfolioProjectsSection from "../components/PortfolioProjectsSection.astro";
import PortfolioCtaSection from "../components/PortfolioCtaSection.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <AgencyPageHead title="Portfolio | Web Agency Inc" />
    <style>
      .project-card:hover .project-image {
        transform: scale(1.05);
      }
      .filter-btn.active {
        background-color: black;
        color: white;
      }
    </style>
  </head>
  <body>
    <div class="min-h-screen bg-white flex flex-col">
      <AgencyNavigation
        activeItem="portfolio"
        servicesHref="/service"
        portfolioHref="/portofolio"
        aboutHref="/about"
        contactHref="#contact"
        lang="en"
        switchToEnHref="/portofolio"
        switchToIdHref="/id/portofolio"
      />
      <main class="flex-1 pt-24" style="view-transition-name: main-content">
        <PortfolioHeroSection lang="en" />
        <PortfolioFilterSection lang="en" />
        <PortfolioProjectsSection lang="en" />
        <PortfolioCtaSection lang="en" />
      </main>
      <AgencyFooter
        webDevHref="/service"
        aboutHref="/about"
        contactHref="#contact"
        lang="en"
      />
    </div>
  </body>
</html>
