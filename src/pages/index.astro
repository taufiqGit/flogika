---
import "../styles/global.css";
import AgencyPageHead from "../components/AgencyPageHead.astro";
import AgencyNavigation from "../components/AgencyNavigation.astro";
import AgencyFooter from "../components/AgencyFooter.astro";
import HomeLandingSections from "../components/HomeLandingSections.astro";
---

<!doctype html>
<html lang="id">
  <head>
    <AgencyPageHead title="Flogika | Software Development Agency" />
  </head>
  <body>
    <div class="min-h-screen bg-white flex flex-col">
      <AgencyNavigation
        activeItem="home"
        servicesHref="/service"
        portfolioHref="/portofolio"
        aboutHref="/about"
        contactHref="#contact"
        lang="id"
      />
      <main class="flex-1 pt-24" style="view-transition-name: main-content">
        <HomeLandingSections lang="id" />
      </main>
      <AgencyFooter
        webDevHref="/service"
        aboutHref="/about"
        contactHref="#contact"
        lang="id"
      />
    </div>
  </body>
</html>
