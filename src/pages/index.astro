---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="view-transition" content="same-origin" />
		<title>Modern Web Dev Agency</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
		/>
		<style>
			:root {
				--uber-black: #000000;
				--uber-white: #ffffff;
				--uber-blue: #276ef1;
				--uber-gray: #f3f3f3;
			}
			body {
				font-family: 'Inter', sans-serif;
				background-color: var(--uber-white);
				color: var(--uber-black);
			}
			.tracking-tight-uber {
				letter-spacing: -0.04em;
			}
			@view-transition {
				navigation: auto;
			}
			::view-transition-old(main-content) {
				animation: 0.25s ease-out both fade-out;
			}
			::view-transition-new(main-content) {
				animation: 0.25s ease-in 0.1s both fade-in;
			}
			@keyframes fade-out {
				from {
					opacity: 1;
				}
				to {
					opacity: 0;
				}
			}
			@keyframes fade-in {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}
			sd-component {
				display: block;
			}
		</style>
		<script is:inline src="https://cdn.jsdelivr.net/npm/petite-vue@0.4.1/dist/petite-vue.iife.js" defer></script>
	</head>
	<body>
		<div class="min-h-screen bg-white flex flex-col">
			<div
				v-scope='{ ...{"activeItem":"home","homeHref":"/","servicesHref":"#services","portfolioHref":"#portfolio","aboutHref":"#about","contactHref":"#contact"}, $emit() {} }'
			>
				<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100 px-6 py-4 flex items-center justify-between">
					<div class="flex items-center gap-8">
						<a :href="homeHref" id="nav-logo-link" class="flex items-center"
							><img
								src="https://vgbujcuwptvheqijyjbe.supabase.co/storage/v1/object/public/hmac-uploads/uploads/f9d8c84d-888c-4030-bf75-477f0928ee4d/1766720562184-a0cfc534/uber_logo.svg"
								alt="Logo"
								class="h-6 w-auto"
							/></a
						>
						<div class="hidden md:flex items-center gap-6">
							<a
								:href="servicesHref"
								id="nav-services-link"
								class="text-sm font-medium transition-opacity"
								:class="{ 'text-black opacity-100': activeItem === 'services', 'text-black/60 hover:opacity-70': activeItem !== 'services' }"
								>Services</a
							><a
								:href="portfolioHref"
								id="nav-portfolio-link"
								class="text-sm font-medium transition-opacity"
								:class="{ 'text-black opacity-100': activeItem === 'portfolio', 'text-black/60 hover:opacity-70': activeItem !== 'portfolio' }"
								>Portfolio</a
							><a
								:href="aboutHref"
								id="nav-about-link"
								class="text-sm font-medium transition-opacity"
								:class="{ 'text-black opacity-100': activeItem === 'about', 'text-black/60 hover:opacity-70': activeItem !== 'about' }"
								>About</a
							>
						</div>
					</div>
					<div class="flex items-center gap-4">
						<a
							:href="contactHref"
							id="nav-cta-btn"
							class="bg-black text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-zinc-800 transition-all"
							>Contact Us</a
						><button @click="$emit('toggleMobileMenu')" class="md:hidden flex items-center p-2">
							<iconify-icon icon="lucide:menu" class="text-2xl"></iconify-icon>
						</button>
					</div>
				</nav>
			</div>

			<main class="flex-1 pt-24" style="view-transition-name: main-content">
				<section class="px-6 lg:px-12 py-16 lg:py-24 max-w-7xl mx-auto">
					<div class="grid lg:grid-cols-2 gap-16 items-center">
						<div class="space-y-8">
							<div class="inline-block bg-black text-white px-3 py-1 text-[10px] uppercase tracking-widest font-bold">
								Development Agency
							</div>
							<h1 class="text-6xl lg:text-8xl font-extrabold tracking-tight-uber leading-none">
								We build the <span class="text-[#276EF1]">future</span> of web.
							</h1>
							<p class="text-xl text-zinc-600 max-w-lg">
								Crafting high-performance digital experiences that drive growth, efficiency, and scale for businesses globally.
							</p>
							<div class="flex items-center gap-4">
								<a href="#contact" id="hero-start-btn" class="bg-black text-white px-8 py-4 text-base font-bold flex items-center gap-3 hover:bg-zinc-800 transition-all">
									Start a project
									<iconify-icon icon="lucide:arrow-right"></iconify-icon>
								</a>
								<a href="#portfolio" id="hero-work-link" class="text-black font-semibold border-b-2 border-black pb-1 hover:text-[#276EF1] hover:border-[#276EF1] transition-all">
									View our work
								</a>
							</div>
						</div>
						<div class="relative">
							<div class="absolute -inset-4 bg-zinc-100 rounded-3xl -z-10 transform rotate-2"></div>
							<img
								src="https://pquxfbbxflqvtidtlrhl.supabase.co/storage/v1/object/public/hmac-uploads/brand/aa611a48-0f31-4fc3-91b8-a97e15fbee97/assets/cd41ecf3-24c9-407d-8b6f-51ed14683272.webp"
								alt="Web Development Dashboard"
								class="rounded-2xl shadow-2xl w-full h-[500px] object-cover"
							/>
						</div>
					</div>
				</section>

				<section id="services" class="bg-[#F3F3F3] py-24 px-6 lg:px-12">
					<div class="max-w-7xl mx-auto">
						<div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
							<div class="max-w-xl">
								<h2 class="text-4xl font-bold tracking-tight-uber mb-4">Core Capabilities</h2>
								<p class="text-zinc-600">From early-stage startups to enterprise systems, we provide end-to-end development services tailored to your needs.</p>
							</div>
							<a href="/services" id="services-all-link" class="text-sm font-bold flex items-center gap-2 hover:text-[#276EF1] transition-colors">
								All services <iconify-icon icon="lucide:chevron-right"></iconify-icon>
							</a>
						</div>

						<div class="grid md:grid-cols-3 gap-8">
							<div class="bg-white p-8 group hover:shadow-xl transition-all">
								<div class="w-12 h-12 bg-black text-white flex items-center justify-center mb-6">
									<iconify-icon icon="lucide:monitor" class="text-2xl"></iconify-icon>
								</div>
								<h3 class="text-2xl font-bold mb-3">Frontend Dev</h3>
								<p class="text-zinc-500 mb-6">Highly interactive, performant, and responsive interfaces built with React, Vue, and Tailwind CSS.</p>
								<ul class="space-y-2 text-sm font-medium">
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> Headless Architecture</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> Next.js Performance</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> Design System Dev</li>
								</ul>
							</div>

							<div class="bg-white p-8 group hover:shadow-xl transition-all">
								<div class="w-12 h-12 bg-black text-white flex items-center justify-center mb-6">
									<iconify-icon icon="lucide:server" class="text-2xl"></iconify-icon>
								</div>
								<h3 class="text-2xl font-bold mb-3">Backend Systems</h3>
								<p class="text-zinc-500 mb-6">Scalable, secure, and robust server-side solutions powering your most critical business logic.</p>
								<ul class="space-y-2 text-sm font-medium">
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> API Development</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> Cloud Infrastructure</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> Database Architecture</li>
								</ul>
							</div>

							<div class="bg-white p-8 group hover:shadow-xl transition-all">
								<div class="w-12 h-12 bg-black text-white flex items-center justify-center mb-6">
									<iconify-icon icon="lucide:layout-grid" class="text-2xl"></iconify-icon>
								</div>
								<h3 class="text-2xl font-bold mb-3">Digital Products</h3>
								<p class="text-zinc-500 mb-6">Comprehensive product strategy and development to bring your visionary ideas to market.</p>
								<ul class="space-y-2 text-sm font-medium">
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> SaaS Platforms</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> E-commerce Solutions</li>
									<li class="flex items-center gap-2"><iconify-icon icon="lucide:check" class="text-[#276EF1]"></iconify-icon> MVP Development</li>
								</ul>
							</div>
						</div>
					</div>
				</section>

				<section class="py-24 px-6 lg:px-12 max-w-7xl mx-auto">
					<div class="grid md:grid-cols-4 gap-12 border-y border-zinc-100 py-16">
						<div class="text-center">
							<div class="text-5xl font-extrabold tracking-tight-uber mb-2">150+</div>
							<div class="text-zinc-500 text-sm font-semibold uppercase">Projects Delivered</div>
						</div>
						<div class="text-center">
							<div class="text-5xl font-extrabold tracking-tight-uber mb-2">12</div>
							<div class="text-zinc-500 text-sm font-semibold uppercase">Global Regions</div>
						</div>
						<div class="text-center">
							<div class="text-5xl font-extrabold tracking-tight-uber mb-2">99%</div>
							<div class="text-zinc-500 text-sm font-semibold uppercase">Client Retention</div>
						</div>
						<div class="text-center">
							<div class="text-5xl font-extrabold tracking-tight-uber mb-2">10M+</div>
							<div class="text-zinc-500 text-sm font-semibold uppercase">Users Reached</div>
						</div>
					</div>
				</section>

				<section id="contact" class="px-6 py-24 bg-black text-white">
					<div class="max-w-4xl mx-auto text-center">
						<h2 class="text-4xl lg:text-6xl font-extrabold tracking-tight-uber mb-8">
							Ready to redefine your <span class="text-[#276EF1]">digital presence?</span>
						</h2>
						<p class="text-xl text-zinc-400 mb-12">
							Partner with our expert development team to build high-impact web solutions that scale.
						</p>
						<div class="flex flex-col sm:flex-row items-center justify-center gap-6">
							<a href="#" id="cta-primary-btn" class="bg-white text-black px-12 py-5 text-lg font-bold hover:bg-zinc-200 transition-all w-full sm:w-auto">
								Start a Project
							</a>
							<a href="#" id="cta-secondary-btn" class="bg-zinc-900 border border-zinc-700 text-white px-12 py-5 text-lg font-bold hover:bg-zinc-800 transition-all w-full sm:w-auto">
								Our Process
							</a>
						</div>
					</div>
				</section>
			</main>

			<div
				v-scope='{ ...{"currentYear":2026,"companyName":"Web Agency Inc","twitterHref":"#","linkedinHref":"#","githubHref":"#","webDevHref":"#","cloudHref":"#","designHref":"#","ecommerceHref":"#","aboutHref":"#","careersHref":"#","blogHref":"#","contactHref":"#","privacyHref":"#","termsHref":"#"}, $emit() {} }'
			>
				<footer class="bg-white py-16 px-6 lg:px-12 border-t border-zinc-100">
					<div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-12">
						<div class="col-span-1 md:col-span-2 space-y-6">
							<img
								src="https://vgbujcuwptvheqijyjbe.supabase.co/storage/v1/object/public/hmac-uploads/uploads/f9d8c84d-888c-4030-bf75-477f0928ee4d/1766720562184-a0cfc534/uber_logo.svg"
								alt="Logo"
								class="h-5 w-auto"
							/>
							<p class="text-zinc-500 max-w-sm">
								A design-driven development agency committed to excellence, performance, and the craft of digital product building.
							</p>
							<div class="flex gap-4">
								<a :href="twitterHref" id="social-twitter" class="text-zinc-400 hover:text-black transition-colors">
									<iconify-icon icon="brandico:twitter-bird" class="text-xl"></iconify-icon>
								</a>
								<a :href="linkedinHref" id="social-linkedin" class="text-zinc-400 hover:text-black transition-colors">
									<iconify-icon icon="brandico:linkedin" class="text-xl"></iconify-icon>
								</a>
								<a :href="githubHref" id="social-github" class="text-zinc-400 hover:text-black transition-colors">
									<iconify-icon icon="brandico:github" class="text-xl"></iconify-icon>
								</a>
							</div>
						</div>
						<div class="space-y-4">
							<h4 class="font-bold uppercase text-xs tracking-widest">Services</h4>
							<ul class="space-y-2 text-zinc-500 text-sm">
								<li><a :href="webDevHref" id="f-web-dev" class="hover:text-black transition-colors">Web Development</a></li>
								<li><a :href="cloudHref" id="f-cloud" class="hover:text-black transition-colors">Cloud Computing</a></li>
								<li><a :href="designHref" id="f-design" class="hover:text-black transition-colors">UX/UI Design</a></li>
								<li><a :href="ecommerceHref" id="f-ecommerce" class="hover:text-black transition-colors">E-commerce</a></li>
							</ul>
						</div>
						<div class="space-y-4">
							<h4 class="font-bold uppercase text-xs tracking-widest">Company</h4>
							<ul class="space-y-2 text-zinc-500 text-sm">
								<li><a :href="aboutHref" id="f-about" class="hover:text-black transition-colors">About Us</a></li>
								<li><a :href="careersHref" id="f-careers" class="hover:text-black transition-colors">Careers</a></li>
								<li><a :href="blogHref" id="f-blog" class="hover:text-black transition-colors">Insights</a></li>
								<li><a :href="contactHref" id="f-contact" class="hover:text-black transition-colors">Contact</a></li>
							</ul>
						</div>
					</div>
					<div class="max-w-7xl mx-auto pt-16 mt-16 border-t border-zinc-100 flex flex-col md:flex-row justify-between gap-4 text-xs text-zinc-400 font-medium">
						<div>&copy; {`{{ currentYear }} {{ companyName }}`}. All rights reserved.</div>
						<div class="flex gap-6">
							<a :href="privacyHref" id="f-privacy" class="hover:text-black">Privacy Policy</a>
							<a :href="termsHref" id="f-terms" class="hover:text-black">Terms of Service</a>
						</div>
					</div>
				</footer>
			</div>
		</div>
		<script is:inline>
			window.addEventListener('DOMContentLoaded', () => {
				window.PetiteVue?.createApp().mount();
			});
		</script>
	</body>
</html>
