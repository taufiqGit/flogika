---
interface Props {
  lang?: "en" | "id";
}

const { lang = "en" } = Astro.props;
const isId = lang === "id";
const backHref = isId ? "/id" : "/";
---

<section>
  <form class="space-y-16">
    <div class="space-y-10">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-bold uppercase tracking-widest mb-4">
            {isId ? "1. Kebutuhan Proyek" : "1. Project Essentials"}
          </label>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="project-name" class="text-xs font-semibold text-zinc-400">
                {isId ? "Nama Proyek" : "Project Name"}
              </label>
              <input
                type="text"
                id="project-name"
                placeholder={isId ? "contoh: Platform Global Acme" : "e.g. Acme Global Platform"}
                class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium"
              />
            </div>
            <div class="space-y-2">
              <label for="company-url" class="text-xs font-semibold text-zinc-400">
                {isId ? "Website Saat Ini (Opsional)" : "Existing Website (Optional)"}
              </label>
              <input
                type="url"
                id="company-url"
                placeholder="https://"
                class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium"
              />
            </div>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-400 mb-4">
            {isId ? "Layanan yang Dibutuhkan" : "Services Required"}
          </label>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="relative"><input type="checkbox" id="service-webapp" class="sr-only custom-checkbox" /><label for="service-webapp" class="flex flex-col items-center justify-center p-4 border border-zinc-200 cursor-pointer hover:bg-zinc-50 transition-all font-semibold text-sm h-full text-center">Web App</label></div>
            <div class="relative"><input type="checkbox" id="service-ecommerce" class="sr-only custom-checkbox" /><label for="service-ecommerce" class="flex flex-col items-center justify-center p-4 border border-zinc-200 cursor-pointer hover:bg-zinc-50 transition-all font-semibold text-sm h-full text-center">E-commerce</label></div>
            <div class="relative"><input type="checkbox" id="service-mobile" class="sr-only custom-checkbox" /><label for="service-mobile" class="flex flex-col items-center justify-center p-4 border border-zinc-200 cursor-pointer hover:bg-zinc-50 transition-all font-semibold text-sm h-full text-center">Mobile App</label></div>
            <div class="relative"><input type="checkbox" id="service-design" class="sr-only custom-checkbox" /><label for="service-design" class="flex flex-col items-center justify-center p-4 border border-zinc-200 cursor-pointer hover:bg-zinc-50 transition-all font-semibold text-sm h-full text-center">UI/UX Design</label></div>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-sm font-bold uppercase tracking-widest mb-4">
          {isId ? "2. Timeline & Anggaran" : "2. Timeline & Budget"}
        </label>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="timeline" class="text-xs font-semibold text-zinc-400">
              {isId ? "Estimasi Timeline" : "Estimated Timeline"}
            </label>
            <select id="timeline" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium">
              <option>{isId ? "2-4 minggu" : "2-4 weeks"}</option>
              <option>{isId ? "1-2 bulan" : "1-2 months"}</option>
              <option>{isId ? "3-6 bulan" : "3-6 months"}</option>
              <option>{isId ? "6+ bulan" : "6+ months"}</option>
            </select>
          </div>
          <div class="space-y-2">
            <label for="budget" class="text-xs font-semibold text-zinc-400">
              {isId ? "Rentang Anggaran" : "Budget Range"}
            </label>
            <select id="budget" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium">
              <option>{isId ? "250K - 500K" : "$5000 - $15000"}</option>
              <option>{isId ? "$15k - $50k" : "$15000 - $50000"}</option>
              <option>{isId ? "$50k - $100k" : "$50000 - $150000"}</option>
              <option>{isId ? "$100k+" : "$150000+"}</option>
            </select>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-sm font-bold uppercase tracking-widest mb-4">
          {isId ? "3. Detail Kontak" : "3. Contact Details"}
        </label>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-2"><label for="full-name" class="text-xs font-semibold text-zinc-400">{isId ? "Nama Lengkap" : "Full Name"}</label><input type="text" id="full-name" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium" /></div>
          <div class="space-y-2"><label for="email" class="text-xs font-semibold text-zinc-400">Email</label><input type="email" id="email" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium" /></div>
          <div class="space-y-2"><label for="phone" class="text-xs font-semibold text-zinc-400">{isId ? "Nomor Telepon" : "Phone Number"}</label><input type="tel" id="phone" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium" /></div>
          <div class="space-y-2"><label for="company" class="text-xs font-semibold text-zinc-400">{isId ? "Perusahaan" : "Company"}</label><input type="text" id="company" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium" /></div>
        </div>
      </div>

      <div>
        <label class="block text-sm font-bold uppercase tracking-widest mb-4">
          {isId ? "4. Ringkasan Proyek" : "4. Project Brief"}
        </label>
        <div class="space-y-2">
          <label for="brief" class="text-xs font-semibold text-zinc-400">
            {isId
              ? "Ceritakan tujuan, tantangan, dan ekspektasi Anda"
              : "Tell us your goals, challenges, and expectations"}
          </label>
          <textarea id="brief" rows="6" class="w-full bg-[#F3F3F3] border-none px-4 py-4 input-focus transition-all font-medium"></textarea>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
      <a href={backHref} class="text-sm font-semibold text-zinc-500 hover:text-black transition-colors">
        {isId ? "Kembali" : "Back"}
      </a>
      <button type="submit" class="bg-black text-white px-10 py-4 text-sm font-bold hover:bg-zinc-800 transition-all">
        {isId ? "Kirim Inquiry" : "Submit Inquiry"}
      </button>
    </div>
  </form>
</section>

<style>
  .input-focus:focus {
    outline: none;
    border-color: var(--uber-blue);
    box-shadow: 0 0 0 1px var(--uber-blue);
  }
  .custom-checkbox:checked + label {
    background-color: var(--uber-black);
    color: var(--uber-white);
    border-color: var(--uber-black);
  }
</style>
