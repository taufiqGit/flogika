---
interface Props {
  lang?: "en" | "id";
}

const { lang = "en" } = Astro.props;
const isIndonesian = lang === "id";
const text = {
  all: isIndonesian ? "Semua Proyek" : "All Projects",
  webDev: isIndonesian ? "Web Dev" : "Web Dev",
  cloud: isIndonesian ? "Sistem Cloud" : "Cloud Systems"
};
---

<section class="px-6 lg:px-12 border-b border-zinc-100 pb-8 max-w-7xl mx-auto mb-12">
  <div class="flex flex-wrap gap-4 items-center">
    <button class="filter-btn active px-6 py-2 rounded-full border border-black text-sm font-bold transition-all">{text.all}</button>
    <button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">{text.webDev}</button>
    <button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">{text.cloud}</button>
    <button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">E-commerce</button>
    <button class="filter-btn px-6 py-2 rounded-full border border-zinc-200 text-zinc-500 text-sm font-bold hover:border-black hover:text-black transition-all">AI/ML</button>
  </div>
</section>
